---
import { stripBase, withBase } from '../lib/paths';

interface NavItem {
	href: string;
	label: string;
}

interface Props {
	currentPath?: string;
}

const { currentPath = '/' } = Astro.props;
const normalizedCurrentPath = stripBase(currentPath);

const items: NavItem[] = [
	{ href: '/', label: 'Inicio' },
	{ href: '/mapa', label: 'Mapa' },
	{ href: '/centros', label: 'Centros' },
	{ href: '/metodologia', label: 'Metodologia' },
	{ href: '/fuentes', label: 'Fuentes' },
];
---

<header class="site-header">
	<a class="site-header__title" href={withBase('/')}>Mapa de Memoria</a>
	<nav class="site-nav" aria-label="Navegacion principal">
		{
			items.map((item) => {
				const isActive =
					item.href === '/'
						? normalizedCurrentPath === '/'
						: normalizedCurrentPath === item.href || normalizedCurrentPath.startsWith(`${item.href}/`);

				return (
					<a href={withBase(item.href)} class={isActive ? 'active' : undefined}>
						{item.label}
					</a>
				);
			})
		}
	</nav>
</header>

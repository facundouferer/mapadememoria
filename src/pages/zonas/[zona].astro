---
import CentroFase1Card from '../../components/CentroFase1Card.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import Layout from '../../layouts/Layout.astro';
import { getCentrosByZonaSlug, getZonas } from '../../lib/centros-fase1';
import { withBase } from '../../lib/paths';

export const getStaticPaths = () => {
	return getZonas().map((zona) => ({
		params: { zona: zona.slug },
		props: { zonaNombre: zona.nombre },
	}));
};

const zonaNombre = Astro.props.zonaNombre as string;
const centros = getCentrosByZonaSlug(Astro.params.zona ?? '');
const hasValue = (value: string | null): value is string => Boolean(value);

const provincias = [...new Set(centros.map((centro) => centro.jerarquia.provincia).filter(hasValue))].sort((a, b) =>
	String(a).localeCompare(String(b), 'es-AR', { numeric: true, sensitivity: 'base' }),
);
const subzonas = [...new Set(centros.map((centro) => centro.jerarquia.subzona).filter(hasValue))].sort((a, b) =>
	String(a).localeCompare(String(b), 'es-AR', { numeric: true, sensitivity: 'base' }),
);
const areas = [...new Set(centros.map((centro) => centro.jerarquia.area).filter(hasValue))].sort((a, b) =>
	String(a).localeCompare(String(b), 'es-AR', { numeric: true, sensitivity: 'base' }),
);
---

<Layout title={`Mapa de Memoria | Zona ${zonaNombre}`}>
	<div class="app-shell">
		<SiteHeader currentPath={Astro.url.pathname} />
		<main class="container">
			<nav class="breadcrumbs" aria-label="Migas de pan">
				<a href={withBase('/')}>Inicio</a>
				<span>/</span>
				<span>Zona {zonaNombre}</span>
			</nav>

			<section class="page-title">
				<h1>Zona: {zonaNombre}</h1>
				<p>{centros.length} centros en esta zona.</p>
			</section>

			<div class="cta-row" style="margin-bottom: 1rem;">
				<a class="button button--secondary" href={withBase(`/centros?zona=${encodeURIComponent(zonaNombre)}`)}>
					Abrir vista filtrada en listados
				</a>
				<a class="button button--secondary" href={withBase(`/mapa?zona=${encodeURIComponent(zonaNombre)}`)}>
					Abrir vista filtrada en mapa
				</a>
				<a class="button button--secondary" href={withBase('/centros?memoria=si')}>Ver lugares con memoria</a>
			</div>

			<div class="chip-row" style="margin-bottom: 0.5rem;">
				{provincias.slice(0, 6).map((provincia) => (
					<a class="chip" href={withBase(`/centros?zona=${encodeURIComponent(zonaNombre)}&provincia=${encodeURIComponent(provincia)}`)}>
						Provincia: {provincia}
					</a>
				))}
				{subzonas.slice(0, 8).map((subzona) => (
					<a class="chip" href={withBase(`/centros?zona=${encodeURIComponent(zonaNombre)}&subzona=${encodeURIComponent(subzona)}`)}>
						Subzona {subzona}
					</a>
				))}
				{areas.slice(0, 8).map((area) => (
					<a class="chip" href={withBase(`/centros?zona=${encodeURIComponent(zonaNombre)}&area=${encodeURIComponent(area)}`)}>
						Area {area}
					</a>
				))}
			</div>

			<section class="card-grid">
				{centros.map((centro) => <CentroFase1Card centro={centro} />)}
			</section>
		</main>
	</div>
</Layout>
